{
  "entities": {
    "Project": {
      "title": "Portfolio Project",
      "description": "Information about a portfolio project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["photography", "video"] },
        "thumbnail": { "type": "string" },
        "media": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "equipment": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "thumbnail", "category"]
    },
    "SiteContent": {
      "title": "Global Site Content",
      "description": "Content for about page, social links, and categories",
      "type": "object",
      "properties": {
        "about": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" },
            "bio": { "type": "string" },
            "email": { "type": "string" },
            "avatar": { "type": "string" }
          }
        },
        "socialLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "platform": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "ko": { "type": "string" },
              "en": { "type": "string" },
              "img": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User portfolio projects"
    },
    "/content/about": {
      "description": "Information for the about page"
    },
    "/content/social": {
      "description": "Social media links"
    },
    "/categories/{categoryId}": {
      "description": "Category item with title and localized names"
    },
    "/content/global": {
      "schema": "SiteContent",
      "description": "Legacy unified configuration (maintained for fallback)"
    }
  }
}
